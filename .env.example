# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# PORT: The port the backend server listens to. Railway automatically injects this.
PORT=3000

# APP_URL: The URL where this applet is hosted (e.g., https://your-app.up.railway.app)
APP_URL="MY_APP_URL"

# Firebase Client Configuration (Optional - The app automatically uses firebase-applet-config.json)
# If you wish to override these in Railway, you can define them here:
VITE_FIREBASE_API_KEY="AIzaSyAbKWCxykuIwXKgAzdzjAbpxtQrAqDI40A"
VITE_FIREBASE_AUTH_DOMAIN="data-absen-uang-makan.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="data-absen-uang-makan"
VITE_FIREBASE_STORAGE_BUCKET="data-absen-uang-makan.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="180976806720"
VITE_FIREBASE_APP_ID="1:180976806720:web:d84cbeb70ada581eace8a5"
